{
  "name": "tldraw-viz",
  "displayName": "tldraw Code Visualizer",
  "description": "Auto-generate tldraw call graph diagrams from source code",
  "version": "2.0.0",
  "publisher": "yadavvi91",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yadavvi91/tldraw-viz"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "tldraw-viz.tldr",
        "displayName": "tldraw Diagram",
        "selector": [
          {
            "filenamePattern": "*.tldr"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "tldraw-viz.showDiagram",
        "title": "Show Code Diagram",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.generateAll",
        "title": "Generate All Diagrams",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.generateFlows",
        "title": "Generate Flow Diagrams",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.convertMermaid",
        "title": "Convert Mermaid to tldraw",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.copySummary",
        "title": "Copy Overview Summary for Claude",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.copyDetailSummary",
        "title": "Copy Detail Summary for Claude",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.generateOverview",
        "title": "Generate Overview Diagram with Claude",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.generateDetail",
        "title": "Generate Detail Diagram with Claude",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.setApiKey",
        "title": "Set Anthropic API Key",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.clearApiKey",
        "title": "Clear Anthropic API Key",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.generateProjectArchitecture",
        "title": "Generate Project Architecture with Claude",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.generateFlowWithClaude",
        "title": "Generate Flow Diagram with Claude",
        "category": "tldraw"
      },
      {
        "command": "tldraw-viz.navigateToFunction",
        "title": "Navigate to Function in Diagram",
        "category": "tldraw"
      }
    ],
    "keybindings": [
      {
        "command": "tldraw-viz.showDiagram",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "tldraw-viz.navigateToFunction",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "tldraw Visualizer",
      "properties": {
        "tldraw-viz.shadowDir": {
          "type": "string",
          "default": ".tldraw",
          "description": "Name of the shadow directory for diagram files"
        },
        "tldraw-viz.minFunctions": {
          "type": "number",
          "default": 3,
          "description": "Minimum number of functions required to generate a diagram"
        },
        "tldraw-viz.mermaidDir": {
          "type": "string",
          "default": ".mermaid",
          "description": "Name of the shadow directory for mermaid diagram files"
        },
        "tldraw-viz.skipPatterns": {
          "type": "array",
          "default": [
            "**/config.*",
            "**/*.d.ts",
            "**/types.*",
            "**/constants.*"
          ],
          "description": "Glob patterns for files to skip during diagram generation"
        },
        "tldraw-viz.freshLineLookup": {
          "type": "boolean",
          "default": true,
          "description": "Re-parse source to find current function line numbers when navigating from diagrams"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:prod": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build:prod && vsce package",
    "lint": "tsc --noEmit",
    "version:patch": "npm version patch --no-git-tag-version && npm run package",
    "version:minor": "npm version minor --no-git-tag-version && npm run package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dagrejs/dagre": "^1.1.4",
    "minimatch": "^10.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tldraw": "^4.4.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.4"
  }
}
